#!/usr/bin/env bash
set -euo pipefail

INSTALL_DIR=/opt/kpanel-client
STATE_DIR=/var/lib/kpanel-client
SERVICE_NAME=kpanel-client.service
LAUNCHER_NAME=kpanel-client-launcher.sh
MODE_HELPER_NAME=kpanel-set-mode
DEFAULTS_DIR=/etc/default
APT_REPO_URL=http://debian.kumpeapps.com
APT_KEYRING=/usr/share/keyrings/KumpeApps.gpg
APT_SOURCE_LIST=/etc/apt/sources.list.d/KumpeApps.list

resolve_runtime_owner() {
	local service_user=""

	if [[ -f "/usr/share/kpanel-client/systemd/$SERVICE_NAME" ]]; then
		service_user="$(sed -n 's/^User=//p' "/usr/share/kpanel-client/systemd/$SERVICE_NAME" | head -n 1)"
	fi

	for candidate in "$service_user" pi kpanel; do
		if [[ -n "$candidate" ]] && id -u "$candidate" >/dev/null 2>&1; then
			printf '%s\n' "$candidate"
			return 0
		fi
	done

	printf '%s\n' root
}

configure_kumpeapps_repo() {
	local key_tmp="${APT_KEYRING}.tmp"
	mkdir -p "$(dirname "$APT_KEYRING")" "$(dirname "$APT_SOURCE_LIST")"

	if command -v curl >/dev/null 2>&1; then
		curl -fsSL "$APT_REPO_URL/public.gpg" | gpg --dearmor > "$key_tmp"
	elif command -v wget >/dev/null 2>&1; then
		wget -qO- "$APT_REPO_URL/public.gpg" | gpg --dearmor > "$key_tmp"
	else
		echo "Warning: neither curl nor wget is available; skipping KumpeApps repo setup." >&2
		return 1
	fi

	chmod 644 "$key_tmp"
	mv "$key_tmp" "$APT_KEYRING"
	printf 'deb [signed-by=%s] %s stable main\n' "$APT_KEYRING" "$APT_REPO_URL" > "$APT_SOURCE_LIST"
	chmod 644 "$APT_SOURCE_LIST"
	return 0
}

mkdir -p "$INSTALL_DIR"
cp -r /usr/share/kpanel-client/kpanel_client /usr/share/kpanel-client/requirements.txt "$INSTALL_DIR/"

python3 -m venv "$INSTALL_DIR/.venv"
export PYTHONPATH="$INSTALL_DIR${PYTHONPATH:+:$PYTHONPATH}"
"$INSTALL_DIR/.venv/bin/pip" install --upgrade pip
"$INSTALL_DIR/.venv/bin/pip" install -r "$INSTALL_DIR/requirements.txt"

cp /usr/share/kpanel-client/systemd/$SERVICE_NAME /etc/systemd/system/$SERVICE_NAME
cp /usr/share/kpanel-client/bin/$LAUNCHER_NAME /usr/local/bin/$LAUNCHER_NAME
chmod 755 /usr/local/bin/$LAUNCHER_NAME
for _helper in kpanel-set-mode kpanel-show-mode kpanel-version kpanel-install-version kpanel-prod kpanel-stage kpanel-dev; do
	if [[ -f "/usr/share/kpanel-client/bin/$_helper" ]]; then
		cp "/usr/share/kpanel-client/bin/$_helper" "/usr/local/bin/$_helper"
		chmod 755 "/usr/local/bin/$_helper"
	fi
done
mkdir -p "$STATE_DIR"
RUNTIME_OWNER="$(resolve_runtime_owner)"
chown -R "$RUNTIME_OWNER:$RUNTIME_OWNER" "$INSTALL_DIR" "$STATE_DIR"
mkdir -p "$DEFAULTS_DIR"
if [ ! -f "$DEFAULTS_DIR/kpanel-client" ]; then
	cp /usr/share/kpanel-client/defaults/kpanel-client "$DEFAULTS_DIR/kpanel-client"
fi

if ! configure_kumpeapps_repo; then
	echo "Warning: failed to configure the KumpeApps apt repository; apt-based client updates may be unavailable until the repo is added manually." >&2
fi

# Grant the runtime user permission to set the system timezone without a password.
SUDOERS_FILE="/etc/sudoers.d/kpanel-timedatectl"
SUDOERS_TMP="${SUDOERS_FILE}.tmp"
printf '%s ALL=(root) NOPASSWD: /usr/bin/timedatectl set-timezone *\n' "$RUNTIME_OWNER" > "$SUDOERS_TMP"
chmod 440 "$SUDOERS_TMP"
if visudo -c -f "$SUDOERS_TMP" >/dev/null 2>&1; then
	mv "$SUDOERS_TMP" "$SUDOERS_FILE"
else
	rm -f "$SUDOERS_TMP"
	echo "Warning: sudoers rule validation failed; KPanel timezone changes will not apply." >&2
fi

systemctl daemon-reload
systemctl enable "$SERVICE_NAME"
systemctl restart "$SERVICE_NAME"
