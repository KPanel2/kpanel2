#!/usr/bin/env bash
set -euo pipefail

INSTALL_DIR=/opt/kpanel-client
SERVICE_NAME=kpanel-client.service

mkdir -p "$INSTALL_DIR"
cp -r /usr/share/kpanel-client/kpanel_client /usr/share/kpanel-client/requirements.txt "$INSTALL_DIR/"

python3 -m venv "$INSTALL_DIR/.venv"
"$INSTALL_DIR/.venv/bin/pip" install --upgrade pip
"$INSTALL_DIR/.venv/bin/pip" install -r "$INSTALL_DIR/requirements.txt"

cp /usr/share/kpanel-client/systemd/$SERVICE_NAME /etc/systemd/system/$SERVICE_NAME
systemctl daemon-reload
systemctl enable "$SERVICE_NAME"
systemctl restart "$SERVICE_NAME"
