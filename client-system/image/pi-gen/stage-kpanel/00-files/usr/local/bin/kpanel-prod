#!/usr/bin/env bash
set -euo pipefail

if [[ ${EUID:-$(id -u)} -eq 0 ]]; then
  exec /usr/local/bin/kpanel-set-mode prod
fi

if command -v sudo >/dev/null 2>&1; then
  exec sudo /usr/local/bin/kpanel-set-mode prod
fi

echo "kpanel-prod requires root privileges. Run: sudo kpanel-set-mode prod"
exit 1
