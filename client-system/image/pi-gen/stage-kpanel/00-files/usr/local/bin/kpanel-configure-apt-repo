#!/usr/bin/env bash
set -euo pipefail

APT_REPO_URL="${KPANEL_APT_REPO_URL:-http://debian.kumpeapps.com}"
APT_KEYRING="${KPANEL_APT_KEYRING_PATH:-/usr/share/keyrings/KumpeApps.gpg}"
APT_SOURCE_LIST="${KPANEL_APT_SOURCE_LIST_PATH:-/etc/apt/sources.list.d/KumpeApps.list}"
APT_SUITE="${KPANEL_APT_SUITE:-stable}"

key_tmp="${APT_KEYRING}.tmp"
mkdir -p "$(dirname "$APT_KEYRING")" "$(dirname "$APT_SOURCE_LIST")"

if command -v curl >/dev/null 2>&1; then
	curl -fsSL "$APT_REPO_URL/public.gpg" | gpg --dearmor > "$key_tmp"
elif command -v wget >/dev/null 2>&1; then
	wget -qO- "$APT_REPO_URL/public.gpg" | gpg --dearmor > "$key_tmp"
else
	echo "Warning: neither curl nor wget is available; skipping KumpeApps repo setup." >&2
	exit 1
fi

chmod 644 "$key_tmp"
mv "$key_tmp" "$APT_KEYRING"
printf 'deb [signed-by=%s] %s %s main\n' "$APT_KEYRING" "$APT_REPO_URL" "$APT_SUITE" > "$APT_SOURCE_LIST"
chmod 644 "$APT_SOURCE_LIST"
